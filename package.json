{
  "name": "calcwiz-desktop",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:memory-protocol": "node --test tools/validate-memory-protocol.test.mjs && node tools/validate-memory-protocol.mjs",
    "test:pillars": "node --test tools/validate-pillars.test.mjs && node tools/validate-pillars.mjs",
    "test:golden": "vitest run src/lib/__golden__/golden-runner.test.ts",
    "generate:labs-catalog": "node tools/generate-labs-catalog.mjs",
    "test:labs-catalog": "node --test tools/validate-labs-catalog.test.mjs && node tools/validate-labs-catalog.mjs",
    "test:launch-preflight": "node --test tools/check-tauri-linux-deps.test.mjs",
    "test:unit": "vitest run",
    "test:playground": "vitest run --config vitest.playground.config.ts",
    "playground:ssh-vm": "vite-node playground/level-0-research/external-compute/operator-entrypoint.ts",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "preview:test": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:e2e": "npm run build && playwright test",
    "test:gate": "npm run test:memory-protocol && npm run test:pillars && npm run test:golden && npm run test:labs-catalog && npm run test:unit && npm run test:ui && npm run test:e2e && npm run lint && cargo check --manifest-path src-tauri/Cargo.toml",
    "test:unit:watch": "vitest",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "pretauri:dev": "node tools/check-tauri-linux-deps.mjs",
    "tauri:dev": "npx tauri dev",
    "pretauri:build": "node tools/check-tauri-linux-deps.mjs",
    "tauri:build": "npx tauri build"
  },
  "dependencies": {
    "@cortex-js/compute-engine": "^0.54.1",
    "@fontsource/fira-sans-condensed": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tauri-apps/api": "^2.10.1",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001775",
    "mathlive": "^0.108.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-node": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
